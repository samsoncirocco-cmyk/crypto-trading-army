# Coinbase Advanced Trade API credentials
# Get these from: https://portal.cdp.coinbase.com
# Key name format: organizations/{org_id}/apiKeys/{key_id}
COINBASE_API_KEY_NAME=organizations/xxx/apiKeys/yyy

# PEM-encoded EC private key (use \n for newlines in single-line format)
COINBASE_API_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END EC PRIVATE KEY-----

# Safety switch: set to 'false' to enable REAL trading (default: true = paper mode)
PAPER_MODE=true
